{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PlatformLogsReadCloudWatch",
      "Effect": "Allow",
      "Action": [
        "logs:DescribeLogStreams",
        "logs:FilterLogEvents",
        "logs:GetLogEvents",
        "logs:DescribeLogGroups"
      ],
      "Resource": [
        "arn:aws:logs:ap-south-1:114454670435:log-group:/ecs/zango-india-staging/*",
        "arn:aws:logs:ap-south-1:114454670435:log-group:/ecs/zango-india-prod/*",
        "arn:aws:logs:ap-south-1:114454670435:log-group:/ecs/zango-india-sandbox/*",
        "arn:aws:logs:ap-south-1:114454670435:log-group:/ecs/zango-bms-india-prod/*"
      ]
    }
  ]
}
